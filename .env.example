# ============================================================
# SpecKAI Web Calculator — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# Never commit your real .env file to version control.

# ------------------------------------------------------------
# Supabase Configuration
# Get these from: https://supabase.com -> Project Settings -> API
# ------------------------------------------------------------

# Your Supabase project URL (e.g. https://xyzabc.supabase.co)
co

# Supabase anonymous/public key (safe to use in backend with RLS enabled)
SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key (keep SECRET — server-side only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------
# Backend (Express) Configuration
# ------------------------------------------------------------

# Port for the Express API server
BACKEND_PORT=4000

# Node environment: development | production | test
NODE_ENV=development

# Secret key for signing any tokens/sessions (generate a random string)
SESSION_SECRET=replace-with-a-long-random-secret-string

# ------------------------------------------------------------
# Frontend (Next.js) Configuration
# NEXT_PUBLIC_ prefix exposes variables to the browser
# ------------------------------------------------------------

# Base URL of your Express backend API
# In development: http://localhost:4000
# In production: https://your-api-domain.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# Your Supabase project URL (needed if frontend queries Supabase directly)
co

# Supabase anon key for frontend (safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ------------------------------------------------------------
# CORS Configuration
# ------------------------------------------------------------

# Allowed origin for CORS (your frontend URL)
# In development: http://localhost:3000
CORS_ORIGIN=http://localhost:3000